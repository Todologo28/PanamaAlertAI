APP_NAME=PanamaAlert
APP_ENV=production

SECRET_KEY=change-me-to-a-strong-random-string
JWT_SECRET=change-me-jwt-secret
TOTP_ENC_KEY=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=panama_alert
DB_PASS=panama_alert
DB_NAME=panama_alert

COOKIE_SECURE=true
COOKIE_SAMESITE=Lax
FLASK_DEBUG=false
PREFERRED_URL_SCHEME=https
SERVER_NAME=
LOG_LEVEL=INFO
REQUIRE_STRONG_SECRETS=true
PORT=5000
TRUST_PROXY_COUNT=1
SESSION_MINUTES=60
MAX_ACTIVE_SESSIONS=5000
ACTIVE_SESSION_IDLE_MINUTES=60
REQUESTS_PER_MINUTE=180
REQUESTS_PER_10S=45

# OpenAI - AI moderation (gpt-4o-mini)
OPENAI_API_KEY=sk-your-openai-api-key-here

# SMTP / Email notifications
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-correo@dominio.com
MAIL_PASSWORD=tu-password-o-app-password
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_FROM=tu-correo@dominio.com
MAIL_FROM_NAME=PanamaAlert
